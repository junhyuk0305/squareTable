# 서버 전용 비밀키 — 클라이언트에 절대 노출 금지.
# Edge Function 에서만 접근. 아래 명령으로 등록(.env 아님):
#   supabase secrets set --env-file .supabase-secrets
#
# 이 파일(.supabase-secrets)은 .gitignore 처리됨. 예시만 커밋.

# Supabase service_role (RLS 우회, 서버 전용)
SUPABASE_SERVICE_ROLE_KEY=

# LLM — 저가 호스티드 (둘 중 택1, 데이터 단계에서 확정)
GEMINI_API_KEY=
# OPENAI_API_KEY=

# 임베딩 — 한국어 RAG (bge-m3 자체호스팅 시 불필요)
EMBEDDING_PROVIDER=gemini        # gemini | openai | self_hosted
EMBEDDING_MODEL=text-embedding-004
